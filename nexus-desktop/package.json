{
  "name": "nexus-desktop",
  "version": "1.0.0",
  "description": "Nexus Download Manager - Every byte. Every site. Insanely fast.",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "electron-builder --publish=never",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "download",
    "manager",
    "electron"
  ],
  "author": "Nexus",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.10",
    "aes-js": "^3.1.2",
    "axios": "^1.6.7",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "express": "^4.18.2",
    "fast-xml-parser": "^4.5.4",
    "ffmpeg-static": "^5.2.0",
    "file-type": "^19.0.0",
    "fluent-ffmpeg": "^2.1.2",
    "got": "^13.0.0",
    "hash-sum": "^2.0.0",
    "helmet": "^7.1.0",
    "leven": "^4.0.0",
    "m3u8-parser": "^4.8.0",
    "mime-types": "^2.1.35",
    "morgan": "^1.10.0",
    "mpd-parser": "^1.3.0",
    "node-fetch": "^3.3.2",
    "p-limit": "^3.1.0",
    "p-queue": "^7.4.1",
    "sanitize-filename": "^1.6.3",
    "semver": "^7.6.0",
    "socket.io": "^4.7.4",
    "sql.js": "^1.14.1",
    "tar": "^7.5.10",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nexus.downloader",
    "productName": "Nexus",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main/**/*",
      "renderer/**/*",
      "node_modules/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
