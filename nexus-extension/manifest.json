{
  "manifest_version": 3,
  "name": "Nexus Downloader",
  "version": "1.0.0",
  "description": "Send any download or video to Nexus Download Manager",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest",
    "storage",
    "notifications",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/content.js",
        "content/videoButton.js",
        "content/downloadInterceptor.js",
        "content/playlistButton.js",
        "content/qualityPanel.js",
        "content/sites/youtube.js",
        "content/sites/facebook.js",
        "content/sites/instagram.js",
        "content/sites/twitter.js",
        "content/sites/vimeo.js",
        "content/sites/tiktok.js",
        "content/sites/generic.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Nexus Downloader"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
